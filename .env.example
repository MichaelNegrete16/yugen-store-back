# App
PORT=3000
NODE_ENV=development
CORS_ORIGIN=*

# Base de datos (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=yugen

# Pasarela de pago (sandbox) — nombres GENERICOS, nunca el nombre real
# GATEWAY_MODE: stub (respuestas locales, sin red) o http (pasarela real sandbox)
GATEWAY_MODE=stub
GATEWAY_BASE_URL=https://sandbox.gateway/v1
GATEWAY_PUBLIC_KEY=pub_test_xxx
GATEWAY_PRIVATE_KEY=prv_test_xxx
GATEWAY_INTEGRITY_SECRET=test_integrity_xxx
GATEWAY_EVENTS_SECRET=test_events_xxx
GATEWAY_CURRENCY=COP

# Reglas de negocio
SHIPPING_COP=15000
IVA_RATE=0.19
DISCOUNT_CODE=YUGEN10
DISCOUNT_RATE=0.10
