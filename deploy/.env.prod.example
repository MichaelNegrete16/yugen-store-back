# Plantilla del .env de PRODUCCION en la VPS (/opt/yugen-store/.env).
# Copiar como .env y rellenar con los valores reales. NUNCA se versiona.

# App
PORT=3000
# development deja que TypeORM cree el esquema y corra el seed al levantar.
# (En un entorno real se manejaria con migraciones.)
NODE_ENV=development
CORS_ORIGIN=*

# Base de datos (interna del stack)
DB_HOST=yugen_postgres
DB_PORT=5432
DB_USER=yugen
DB_PASSWORD=cambia-esta-clave
DB_NAME=yugen

# Pasarela de pago (sandbox) — integracion real
GATEWAY_MODE=http
# URL del sandbox de la pasarela de pago (ver documentacion de la pasarela).
GATEWAY_BASE_URL=https://api-sandbox.<pasarela>.example/v1
GATEWAY_PUBLIC_KEY=pub_stagtest_xxx
GATEWAY_PRIVATE_KEY=prv_stagtest_xxx
GATEWAY_INTEGRITY_SECRET=stagtest_integrity_xxx
GATEWAY_EVENTS_SECRET=stagtest_events_xxx
GATEWAY_CURRENCY=COP

# Reglas de negocio
SHIPPING_COP=15000
IVA_RATE=0.19
DISCOUNT_CODE=YUGEN10
DISCOUNT_RATE=0.10

# El Cloudflare Tunnel es locally-managed: sus credenciales y config viven en
# ./cloudflared (no van por variables de entorno).
